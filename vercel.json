{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/" }
  ],
  "crons": [
    {
      "path": "/api/daily-summary",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/reminder",
      "schedule": "0 */6 * * *"
    }
  ]
}
