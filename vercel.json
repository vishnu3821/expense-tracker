{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/|@|src/|node_modules/)(?!.*\\.).*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/reminder",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/daily-summary",
      "schedule": "30 15 * * *"
    },
    {
      "path": "/api/monthly-report",
      "schedule": "0 9 1 * *"
    }
  ]
}
